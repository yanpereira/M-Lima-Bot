# =========================================================
# 🔒 ARQUIVO DE CONFIGURAÇÃO - TEMPLATE (.env.example)
# Renomeie este arquivo para .env e preencha com seus dados.
# NUNCA comite o arquivo .env preenchido no controle de versão!
# =========================================================

# 🌐 Credenciais do Sistema GigaTech (Mentora Soluções)
# Dica: Use a URL limpa de login, sem os parâmetros de sessão (jsessionid)
GIGATECH_URL=https://app.mentorasolucoes.com.br/Voti-1.0.7/login.xhtml
GIGATECH_USER=seu_email_de_acesso@dominio.com
GIGATECH_PASS=sua_senha_de_acesso

# 🪣 Credenciais do Data Lake (MinIO na VPS)
# Endpoint limpo (sem http:// ou https:// na frente, o código já injeta isso)
MINIO_ENDPOINT=seu-endpoint-minio.easypanel.host
MINIO_ACCESS_KEY=seu_usuario_do_minio
MINIO_SECRET_KEY=sua_senha_secreta_do_minio
MINIO_SECURE=true